      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "margin_right",
      "label": "Margine destro",
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "color",
      "id": "background_color",
