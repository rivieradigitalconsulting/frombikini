{% doc %}
  @prompt
    ciao, ho bisogno di una sezione che si compili max 8, che possono essere quadrati o circolari. Posso decidere la distanza del modulo ai lati e sopra e sotto come Margine. Posso decidere distanza tra gli elementi. Posso decidere la spaziature tra le righe sia desktop che mobile. Posso decidere disposizione a desktop e mobile (desktop da 2 fino a 4 per riga, mobile da 2 fino a 3 per riga). A mobile e desktop posso decidere anche di visualizzare a slider o a griglia. Lo slider ha dei bottoni classici di cui posso scegliere colore e grandezza, sia desktop che mobile. Passiamo alle caratteristiche degli elementi. Testo centrale, posso decidere per ogni dispositivo font e dimensioni del testo. Poi sotto all'elemento un titolo e un sottotitolo di cui posso scegliere per ognuno font e dimensioni, giustifica e spaziatura tra i due elementi. L'elemento deve essere compilato con un immagine.,  Per ogni elemento aggiungimi la possibilità di inserire un link -  Ogni elemento inoltre deve avere un setting di tipo slider che decide da 1 a 8 la posizione all'interno del modulo. Importantissimo sottolineare che se un elemento non è valorizzato, quindi vuoto in tutti i campi non deve apparire, ho provato ad allestirne uno, ma non funziona. La regola è che basta almeno un campo dell'elemento allestito per far sì che appaia in viauslizzazione, altrimenti deve essere nascosto. Aggiungere un titolo di cui posso selezionare dimensioni per ogni device, e font e distanza dalla griglia/slider. E dopo la griglia slider un bottone, prendimi gli stili del tema, quindi o pieno o solo con il contorno o a testo selezionato. Anche di questo bottone fammi decidere posizione giustificata colori, dimensioni testo per device e colore, devo poter decidere del titolo anche giustifica destra sinistra o centro, rispettando allineamento del tema. Anche il colore del testo. E poi della sezione devo poter decidere background color. Non funziona slider ne a desktop, ne a mobile, non funziona slider ancora. Da mobile ne ho aggiunti 3, sopra la soglia delle colonne impostate per desktop mobile si dovrebbe attivare lo slider, inseriscimi solo impostazioni di apertura DI TUTTI link (in nuova o stessa pagina) - rimuovimi opzione di slider che non la voglio, quindi anche dei bottoni che non servono. Bottoni impostazione per mettere testo in bold. Portami il massimo delle colonne desktop a 6. Dammi possibilità di decidere distanza tra la griglia e il bottone
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% liquid
  assign items = block.settings.items | default: 8
  assign active_items = 0
  
  for i in (1..8)
    assign image_key = 'item_' | append: i | append: '_image'
    assign text_key = 'item_' | append: i | append: '_text'
    assign title_key = 'item_' | append: i | append: '_title'
    assign subtitle_key = 'item_' | append: i | append: '_subtitle'
    assign link_key = 'item_' | append: i | append: '_link'
    
    assign has_image = block.settings[image_key]
    assign has_text = block.settings[text_key]
    assign has_title = block.settings[title_key]
    assign has_subtitle = block.settings[subtitle_key]
    assign has_link = block.settings[link_key]
    
    if has_image or has_text or has_title or has_subtitle or has_link
      assign active_items = active_items | plus: 1
    endif
  endfor
%}

{% style %}
  .ai-icon-grid-{{ ai_gen_id }} {
    background-color: {{ block.settings.background_color }};
    padding-top: {{ block.settings.margin_top }}px;
    padding-bottom: {{ block.settings.margin_bottom }}px;
    padding-left: {{ block.settings.margin_left }}px;
    padding-right: {{ block.settings.margin_right }}px;
    width: 100%;
  }

  .ai-icon-grid-container-{{ ai_gen_id }} {
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-icon-grid-title-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.title_spacing }}px;
    font-family: {{ block.settings.title_font.family }}, {{ block.settings.title_font.fallback_families }};
    font-weight: {{ block.settings.title_font.weight }};
    font-style: {{ block.settings.title_font.style }};
    text-align: {{ block.settings.title_alignment }};
    color: {{ block.settings.title_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-icon-grid-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size_mobile }}px;
    }
  }

  @media screen and (min-width: 750px) {
    .ai-icon-grid-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size_desktop }}px;
    }
  }

  .ai-icon-grid-wrapper-{{ ai_gen_id }} {
    display: grid;
    gap: {{ block.settings.gap_mobile }}px;
    grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    row-gap: {{ block.settings.row_gap_mobile }}px;
  }

  @media screen and (min-width: 750px) {
    .ai-icon-grid-wrapper-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
      gap: {{ block.settings.gap_desktop }}px;
      row-gap: {{ block.settings.row_gap_desktop }}px;
    }
  }

  .ai-icon-grid-item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    text-decoration: none;
    color: inherit;
  }

  .ai-icon-grid-item-{{ ai_gen_id }}:hover {
    text-decoration: none;
  }

  .ai-icon-grid-icon-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    margin-bottom: {{ block.settings.text_spacing }}px;
    {% if block.settings.icon_shape == 'circle' %}
      border-radius: 50%;
      overflow: hidden;
    {% endif %}
  }

  .ai-icon-grid-icon-wrapper-{{ ai_gen_id }}::before {
    content: '';
    display: block;
    padding-bottom: 100%;
  }

  .ai-icon-grid-icon-content-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-icon-grid-icon-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-icon-grid-text-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-family: {{ block.settings.text_font.family }}, {{ block.settings.text_font.fallback_families }};
    font-weight: {{ block.settings.text_font.weight }};
    font-style: {{ block.settings.text_font.style }};
    color: {{ block.settings.text_color }};
    z-index: 1;
    {% if block.settings.text_bold %}
      font-weight: 700;
    {% endif %}
  }

  @media screen and (max-width: 749px) {
    .ai-icon-grid-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size_mobile }}px;
    }
  }

  @media screen and (min-width: 750px) {
    .ai-icon-grid-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size_desktop }}px;
    }
  }

  .ai-icon-grid-item-title-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.title_subtitle_spacing }}px;
    font-family: {{ block.settings.item_title_font.family }}, {{ block.settings.item_title_font.fallback_families }};
    font-weight: {{ block.settings.item_title_font.weight }};
    font-style: {{ block.settings.item_title_font.style }};
    text-align: {{ block.settings.item_text_alignment }};
    color: {{ block.settings.item_title_color }};
    {% if block.settings.item_title_bold %}
      font-weight: 700;
    {% endif %}
  }

  @media screen and (max-width: 749px) {
    .ai-icon-grid-item-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.item_title_size_mobile }}px;
    }
  }

  @media screen and (min-width: 750px) {
    .ai-icon-grid-item-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.item_title_size_desktop }}px;
    }
  }

  .ai-icon-grid-item-subtitle-{{ ai_gen_id }} {
    margin: 0;
    font-family: {{ block.settings.item_subtitle_font.family }}, {{ block.settings.item_subtitle_font.fallback_families }};
    font-weight: {{ block.settings.item_subtitle_font.weight }};
    font-style: {{ block.settings.item_subtitle_font.style }};
    text-align: {{ block.settings.item_text_alignment }};
    color: {{ block.settings.item_subtitle_color }};
    {% if block.settings.item_subtitle_bold %}
      font-weight: 700;
    {% endif %}
  }

  @media screen and (max-width: 749px) {
    .ai-icon-grid-item-subtitle-{{ ai_gen_id }} {
      font-size: {{ block.settings.item_subtitle_size_mobile }}px;
    }
  }

  @media screen and (min-width: 750px) {
    .ai-icon-grid-item-subtitle-{{ ai_gen_id }} {
      font-size: {{ block.settings.item_subtitle_size_desktop }}px;
    }
  }

  .ai-icon-grid-button-wrapper-{{ ai_gen_id }} {
    margin-top: {{ block.settings.button_spacing }}px;
    text-align: {{ block.settings.button_alignment }};
  }

  .ai-icon-grid-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 12px 24px;
    text-decoration: none;
    border-radius: {{ settings.button_border_radius }}px;
    font-family: {% if settings.button_text_font == 'heading' %}{{ settings.heading_font.family }}, {{ settings.heading_font.fallback_families }}{% else %}{{ settings.text_font.family }}, {{ settings.text_font.fallback_families }}{% endif %};
    font-weight: {% if settings.button_text_font == 'heading' %}{{ settings.heading_font.weight }}{% else %}{{ settings.text_font.weight }}{% endif %};
    text-transform: {{ settings.button_text_transform }};
    letter-spacing: {{ settings.button_letter_spacing | divided_by: 100.0 }}em;
    transition: all 0.3s ease;
    {% if block.settings.button_bold %}
      font-weight: 700;
    {% endif %}
  }

  @media screen and (max-width: 749px) {
    .ai-icon-grid-button-{{ ai_gen_id }} {
      font-size: {{ block.settings.button_size_mobile }}px;
    }
  }

  @media screen and (min-width: 750px) {
    .ai-icon-grid-button-{{ ai_gen_id }} {
      font-size: {{ block.settings.button_size_desktop }}px;
    }
  }

  .ai-icon-grid-button-{{ ai_gen_id }}--primary {
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    border: 2px solid {{ block.settings.button_bg_color }};
  }

  .ai-icon-grid-button-{{ ai_gen_id }}--primary:hover {
    opacity: 0.8;
  }

  .ai-icon-grid-button-{{ ai_gen_id }}--secondary {
    background-color: transparent;
    color: {{ block.settings.button_bg_color }};
    border: 2px solid {{ block.settings.button_bg_color }};
  }

  .ai-icon-grid-button-{{ ai_gen_id }}--secondary:hover {
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
  }

  .ai-icon-grid-button-{{ ai_gen_id }}--link {
    background-color: transparent;
    color: {{ block.settings.button_bg_color }};
    border: none;
    padding: 0;
    text-decoration: underline;
  }

  .ai-icon-grid-button-{{ ai_gen_id }}--link:hover {
    opacity: 0.7;
  }
{% endstyle %}

<div class="ai-icon-grid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-icon-grid-container-{{ ai_gen_id }}">
    {% if block.settings.section_title != blank %}
      <h2 class="ai-icon-grid-title-{{ ai_gen_id }}">{{ block.settings.section_title }}</h2>
    {% endif %}

    <div class="ai-icon-grid-wrapper-{{ ai_gen_id }}">
      {% liquid
        assign sorted_items = ''
        for i in (1..8)
          assign position_key = 'item_' | append: i | append: '_position'
          assign position = block.settings[position_key]
          
          assign image_key = 'item_' | append: i | append: '_image'
          assign text_key = 'item_' | append: i | append: '_text'
          assign title_key = 'item_' | append: i | append: '_title'
          assign subtitle_key = 'item_' | append: i | append: '_subtitle'
          assign link_key = 'item_' | append: i | append: '_link'
          
          assign has_image = block.settings[image_key]
          assign has_text = block.settings[text_key]
          assign has_title = block.settings[title_key]
          assign has_subtitle = block.settings[subtitle_key]
          assign has_link = block.settings[link_key]
          
          if has_image or has_text or has_title or has_subtitle or has_link
            assign item_data = position | append: '|' | append: i
            if sorted_items == blank
              assign sorted_items = item_data
            else
              assign sorted_items = sorted_items | append: ',' | append: item_data
            endif
          endif
        endfor
        
        assign items_array = sorted_items | split: ','
        assign sorted_array = ''
        
        for pos in (1..8)
          for item in items_array
            assign item_parts = item | split: '|'
            assign item_position = item_parts[0] | plus: 0
            if item_position == pos
              if sorted_array == blank
                assign sorted_array = item
              else
                assign sorted_array = sorted_array | append: ',' | append: item
              endif
            endif
          endfor
        endfor
        
        if sorted_array == blank
          assign sorted_array = sorted_items
        endif
      %}

      {% assign final_items = sorted_array | split: ',' %}
      {% for item in final_items %}
        {% assign item_parts = item | split: '|' %}
        {% assign i = item_parts[1] | plus: 0 %}
        
        {% liquid
          assign image_key = 'item_' | append: i | append: '_image'
          assign text_key = 'item_' | append: i | append: '_text'
          assign title_key = 'item_' | append: i | append: '_title'
          assign subtitle_key = 'item_' | append: i | append: '_subtitle'
          assign link_key = 'item_' | append: i | append: '_link'
          
          assign item_image = block.settings[image_key]
          assign item_text = block.settings[text_key]
          assign item_title = block.settings[title_key]
          assign item_subtitle = block.settings[subtitle_key]
          assign item_link = block.settings[link_key]
        %}

        {% if item_link != blank %}
          <a 
            href="{{ item_link }}" 
            class="ai-icon-grid-item-{{ ai_gen_id }}"
            {% if block.settings.link_target == 'new' %}target="_blank" rel="noopener noreferrer"{% endif %}
          >
        {% else %}
          <div class="ai-icon-grid-item-{{ ai_gen_id }}">
        {% endif %}

          <div class="ai-icon-grid-icon-wrapper-{{ ai_gen_id }}">
            <div class="ai-icon-grid-icon-content-{{ ai_gen_id }}">
              {% if item_image %}
                <img
                  src="{{ item_image | image_url: width: 500 }}"
                  alt="{{ item_title | default: item_text | escape }}"
                  class="ai-icon-grid-icon-{{ ai_gen_id }}"
                  loading="lazy"
                  width="500"
                  height="500"
                >
              {% endif %}
              {% if item_text != blank %}
                <div class="ai-icon-grid-text-{{ ai_gen_id }}">{{ item_text }}</div>
              {% endif %}
            </div>
          </div>

          {% if item_title != blank %}
            <h3 class="ai-icon-grid-item-title-{{ ai_gen_id }}">{{ item_title }}</h3>
          {% endif %}

          {% if item_subtitle != blank %}
            <p class="ai-icon-grid-item-subtitle-{{ ai_gen_id }}">{{ item_subtitle }}</p>
          {% endif %}

        {% if item_link != blank %}
          </a>
        {% else %}
          </div>
        {% endif %}
      {% endfor %}
    </div>

    {% if block.settings.button_text != blank and block.settings.button_link != blank %}
      <div class="ai-icon-grid-button-wrapper-{{ ai_gen_id }}">
        <a 
          href="{{ block.settings.button_link }}" 
          class="ai-icon-grid-button-{{ ai_gen_id }} ai-icon-grid-button-{{ ai_gen_id }}--{{ block.settings.button_style }}"
          {% if block.settings.link_target == 'new' %}target="_blank" rel="noopener noreferrer"{% endif %}
        >
          {{ block.settings.button_text }}
        </a>
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Griglia icone",
  "settings": [
    {
      "type": "header",
      "content": "Titolo sezione"
    },
    {
      "type": "text",
      "id": "section_title",
      "label": "Titolo"
    },
    {
      "type": "font_picker",
      "id": "title_font",
      "label": "Font titolo",
      "default": "helvetica_n4"
    },
    {
      "type": "range",
      "id": "title_size_mobile",
      "label": "Dimensione titolo mobile",
      "min": 12,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "title_size_desktop",
      "label": "Dimensione titolo desktop",
      "min": 12,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "select",
      "id": "title_alignment",
      "label": "Allineamento titolo",
      "options": [
        { "value": "left", "label": "Sinistra" },
        { "value": "center", "label": "Centro" },
        { "value": "right", "label": "Destra" }
      ],
      "default": "center"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Colore titolo",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "title_spacing",
      "label": "Distanza titolo dalla griglia",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 30
    },
    {
      "type": "header",
      "content": "Layout griglia"
    },
    {
      "type": "select",
      "id": "icon_shape",
      "label": "Forma elemento",
      "options": [
        { "value": "square", "label": "Quadrato" },
        { "value": "circle", "label": "Circolare" }
      ],
      "default": "circle"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Colonne desktop",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Colonne mobile",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" }
      ],
      "default": "2"
    },
    {
      "type": "range",
      "id": "gap_desktop",
      "label": "Distanza tra elementi desktop",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "gap_mobile",
      "label": "Distanza tra elementi mobile",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 15
    },
    {
      "type": "range",
      "id": "row_gap_desktop",
      "label": "Spaziatura righe desktop",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 30
    },
    {
      "type": "range",
      "id": "row_gap_mobile",
      "label": "Spaziatura righe mobile",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
