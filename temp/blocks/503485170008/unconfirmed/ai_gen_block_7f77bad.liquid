{% doc %}
  @prompt
    ciao, ho bisogno di una sezione che si compili max 8, che possono essere quadrati o circolari. Posso decidere la distanza del modulo ai lati e sopra e sotto come Margine. Posso decidere distanza tra gli elementi. Posso decidere la spaziature tra le righe sia desktop che mobile. Posso decidere disposizione a desktop e mobile (desktop da 2 fino a 4 per riga, mobile da 2 fino a 3 per riga). A mobile e desktop posso decidere anche di visualizzare a slider o a griglia. Lo slider ha dei bottoni classici di cui posso scegliere colore e grandezza, sia desktop che mobile. Passiamo alle caratteristiche degli elementi. Testo centrale, posso decidere per ogni dispositivo font e dimensioni del testo. Poi sotto all'elemento un titolo e un sottotitolo di cui posso scegliere per ognuno font e dimensioni, giustifica e spaziatura tra i due elementi. L'elemento deve essere compilato con un immagine.,  Per ogni elemento aggiungimi la possibilità di inserire un link -  Ogni elemento inoltre deve avere un setting di tipo slider che decide da 1 a 8 la posizione all'interno del modulo. Importantissimo sottolineare che se un elemento non è valorizzato, quindi vuoto in tutti i campi non deve apparire, ho provato ad allestirne uno, ma non funziona. La regola è che basta almeno un campo dell'elemento allestito per far sì che appaia in viauslizzazione, altrimenti deve essere nascosto. Aggiungere un titolo di cui posso selezionare dimensioni per ogni device, e font e distanza dalla griglia/slider. E dopo la griglia slider un bottone, prendimi gli stili del tema, quindi o pieno o solo con il contorno o a testo selezionato. Anche di questo bottone fammi decidere posizione giustificata colori, dimensioni testo per device e colore, devo poter decidere del titolo anche giustifica destra sinistra o centro, rispettando allineamento del tema. Anche il colore del testo. E poi della sezione devo poter decidere background color. Non funziona slider ne a desktop, ne a mobile
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% liquid
  assign items = ''
  for i in (1..8)
    assign image_key = 'item_' | append: i | append: '_image'
    assign text_key = 'item_' | append: i | append: '_text'
    assign title_key = 'item_' | append: i | append: '_title'
    assign subtitle_key = 'item_' | append: i | append: '_subtitle'
    assign link_key = 'item_' | append: i | append: '_link'
    assign position_key = 'item_' | append: i | append: '_position'
    
    assign has_content = false
    if block.settings[image_key] != blank or block.settings[text_key] != blank or block.settings[title_key] != blank or block.settings[subtitle_key] != blank
      assign has_content = true
    endif
    
    if has_content
      assign item_data = block.settings[position_key] | append: '|' | append: i
      if items == blank
        assign items = item_data
      else
        assign items = items | append: ',' | append: item_data
      endif
    endif
  endfor
  
  assign items_array = items | split: ','
  assign sorted_items = items_array | sort
%}

{% style %}
  .ai-icon-grid-{{ ai_gen_id }} {
    width: 100%;
    padding: {{ block.settings.margin_top }}px {{ block.settings.margin_horizontal }}px {{ block.settings.margin_bottom }}px;
    background-color: {{ block.settings.section_bg_color }};
    display: block;
  }

  .ai-icon-grid__title-{{ ai_gen_id }} {
    font-family: {{ block.settings.title_font.family }}, {{ block.settings.title_font.fallback_families }};
    font-weight: {{ block.settings.title_font.weight }};
    font-style: {{ block.settings.title_font.style }};
    font-size: {{ block.settings.title_size_mobile }}px;
    margin-bottom: {{ block.settings.title_spacing }}px;
    text-align: {{ block.settings.title_align }};
    color: {{ block.settings.title_color }};
    margin-top: 0;
  }

  .ai-icon-grid__container-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
  }

  .ai-icon-grid__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    gap: {{ block.settings.gap_mobile }}px;
    row-gap: {{ block.settings.row_gap_mobile }}px;
  }

  .ai-icon-grid__slider-{{ ai_gen_id }} {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    gap: {{ block.settings.gap_mobile }}px;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .ai-icon-grid__slider-{{ ai_gen_id }}::-webkit-scrollbar {
    display: none;
  }

  .ai-icon-grid__slider-{{ ai_gen_id }} .ai-icon-grid__item-{{ ai_gen_id }} {
    flex: 0 0 calc((100% - ({{ block.settings.columns_mobile | minus: 1 }} * {{ block.settings.gap_mobile }}px)) / {{ block.settings.columns_mobile }});
    scroll-snap-align: start;
  }

  .ai-icon-grid__item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .ai-icon-grid__item-link-{{ ai_gen_id }} {
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
  }

  .ai-icon-grid__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    aspect-ratio: 1;
    margin-bottom: {{ block.settings.text_spacing }}px;
    {% if block.settings.shape == 'circle' %}
      border-radius: 50%;
    {% endif %}
    overflow: hidden;
  }

  .ai-icon-grid__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-icon-grid__image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-icon-grid__image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 200px;
    max-height: 200px;
  }

  .ai-icon-grid__text-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    color: {{ block.settings.overlay_text_color }};
    font-family: {{ block.settings.overlay_font.family }}, {{ block.settings.overlay_font.fallback_families }};
    font-weight: {{ block.settings.overlay_font.weight }};
    font-style: {{ block.settings.overlay_font.style }};
    font-size: {{ block.settings.overlay_size_mobile }}px;
    text-align: center;
    width: 90%;
  }

  .ai-icon-grid__title-text-{{ ai_gen_id }} {
    font-family: {{ block.settings.item_title_font.family }}, {{ block.settings.item_title_font.fallback_families }};
    font-weight: {{ block.settings.item_title_font.weight }};
    font-style: {{ block.settings.item_title_font.style }};
    font-size: {{ block.settings.item_title_size_mobile }}px;
    margin: 0 0 {{ block.settings.title_subtitle_gap }}px 0;
    text-align: {{ block.settings.text_align }};
  }

  .ai-icon-grid__subtitle-text-{{ ai_gen_id }} {
    font-family: {{ block.settings.item_subtitle_font.family }}, {{ block.settings.item_subtitle_font.fallback_families }};
    font-weight: {{ block.settings.item_subtitle_font.weight }};
    font-style: {{ block.settings.item_subtitle_font.style }};
    font-size: {{ block.settings.item_subtitle_size_mobile }}px;
    margin: 0;
    text-align: {{ block.settings.text_align }};
  }

  .ai-icon-grid__nav-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: 10px;
    margin-top: 20px;
  }

  .ai-icon-grid__nav-button-{{ ai_gen_id }} {
    background-color: {{ block.settings.nav_button_color_mobile }};
    border: none;
    width: {{ block.settings.nav_button_size_mobile }}px;
    height: {{ block.settings.nav_button_size_mobile }}px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
  }

  .ai-icon-grid__nav-button-{{ ai_gen_id }}:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .ai-icon-grid__button-wrapper-{{ ai_gen_id }} {
    margin-top: 30px;
    text-align: {{ block.settings.button_alignment }};
  }

  .ai-icon-grid__button-{{ ai_gen_id }} {
    font-family: {{ settings.text_font.family }}, {{ settings.text_font.fallback_families }};
    font-size: {{ block.settings.button_text_size_mobile }}px;
    text-transform: {{ settings.button_text_transform }};
    letter-spacing: {{ settings.button_letter_spacing | divided_by: 100.0 }}em;
    text-decoration: none;
    display: inline-block;
    padding: 12px 24px;
    border-radius: {{ settings.button_border_radius }}px;
    transition: all 0.3s ease;
  }

  .ai-icon-grid__button-{{ ai_gen_id }}--primary {
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    border: 2px solid {{ block.settings.button_bg_color }};
  }

  .ai-icon-grid__button-{{ ai_gen_id }}--secondary {
    background-color: transparent;
    color: {{ block.settings.button_bg_color }};
    border: 2px solid {{ block.settings.button_bg_color }};
  }

  .ai-icon-grid__button-{{ ai_gen_id }}--text {
    background-color: transparent;
    color: {{ block.settings.button_bg_color }};
    border: none;
    text-decoration: underline;
  }

  @media screen and (min-width: 750px) {
    .ai-icon-grid__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size_desktop }}px;
    }

    .ai-icon-grid__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
      gap: {{ block.settings.gap_desktop }}px;
      row-gap: {{ block.settings.row_gap_desktop }}px;
    }

    .ai-icon-grid__slider-{{ ai_gen_id }} {
      gap: {{ block.settings.gap_desktop }}px;
    }

    .ai-icon-grid__slider-{{ ai_gen_id }} .ai-icon-grid__item-{{ ai_gen_id }} {
      flex: 0 0 calc((100% - ({{ block.settings.columns_desktop | minus: 1 }} * {{ block.settings.gap_desktop }}px)) / {{ block.settings.columns_desktop }});
    }

    .ai-icon-grid__text-overlay-{{ ai_gen_id }} {
      font-size: {{ block.settings.overlay_size_desktop }}px;
    }

    .ai-icon-grid__title-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.item_title_size_desktop }}px;
    }

    .ai-icon-grid__subtitle-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.item_subtitle_size_desktop }}px;
    }

    .ai-icon-grid__nav-button-{{ ai_gen_id }} {
      background-color: {{ block.settings.nav_button_color_desktop }};
      width: {{ block.settings.nav_button_size_desktop }}px;
      height: {{ block.settings.nav_button_size_desktop }}px;
    }

    .ai-icon-grid__button-{{ ai_gen_id }} {
      font-size: {{ block.settings.button_text_size_desktop }}px;
    }
  }
{% endstyle %}

<icon-grid-{{ ai_gen_id }} class="ai-icon-grid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.section_title != blank %}
    <h2 class="ai-icon-grid__title-{{ ai_gen_id }}">{{ block.settings.section_title }}</h2>
  {% endif %}

  <div class="ai-icon-grid__container-{{ ai_gen_id }}">
    <div class="ai-icon-grid__layout-container-{{ ai_gen_id }}">
      {% for item in sorted_items %}
        {% assign item_parts = item | split: '|' %}
        {% assign item_index = item_parts[1] %}
        
        {% assign image_key = 'item_' | append: item_index | append: '_image' %}
        {% assign text_key = 'item_' | append: item_index | append: '_text' %}
        {% assign title_key = 'item_' | append: item_index | append: '_title' %}
        {% assign subtitle_key = 'item_' | append: item_index | append: '_subtitle' %}
        {% assign link_key = 'item_' | append: item_index | append: '_link' %}
        
        <div class="ai-icon-grid__item-{{ ai_gen_id }}">
          {% if block.settings[link_key] != blank %}
            <a href="{{ block.settings[link_key] }}" class="ai-icon-grid__item-link-{{ ai_gen_id }}">
          {% endif %}
          
          <div class="ai-icon-grid__image-wrapper-{{ ai_gen_id }}">
            {% if block.settings[image_key] %}
              <img
                src="{{ block.settings[image_key] | image_url: width: 500 }}"
                alt="{{ block.settings[title_key] | default: 'Icon' }}"
                class="ai-icon-grid__image-{{ ai_gen_id }}"
                loading="lazy"
                width="500"
                height="500"
              >
            {% else %}
              <div class="ai-icon-grid__image-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {% endif %}
            
            {% if block.settings[text_key] != blank %}
              <div class="ai-icon-grid__text-overlay-{{ ai_gen_id }}">
                {{ block.settings[text_key] }}
              </div>
            {% endif %}
          </div>
          
          {% if block.settings[title_key] != blank %}
            <h3 class="ai-icon-grid__title-text-{{ ai_gen_id }}">{{ block.settings[title_key] }}</h3>
          {% endif %}
          
          {% if block.settings[subtitle_key] != blank %}
            <p class="ai-icon-grid__subtitle-text-{{ ai_gen_id }}">{{ block.settings[subtitle_key] }}</p>
          {% endif %}
          
          {% if block.settings[link_key] != blank %}
            </a>
          {% endif %}
        </div>
      {% endfor %}
    </div>

    <div class="ai-icon-grid__nav-{{ ai_gen_id }}" style="display: none;">
      <button class="ai-icon-grid__nav-button-{{ ai_gen_id }}" data-direction="prev" aria-label="Precedente">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M10 12L6 8L10 4"/>
        </svg>
      </button>
      <button class="ai-icon-grid__nav-button-{{ ai_gen_id }}" data-direction="next" aria-label="Successivo">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M6 4L10 8L6 12"/>
        </svg>
      </button>
    </div>
  </div>

  {% if block.settings.button_text != blank and block.settings.button_link != blank %}
    <div class="ai-icon-grid__button-wrapper-{{ ai_gen_id }}">
      <a 
        href="{{ block.settings.button_link }}" 
        class="ai-icon-grid__button-{{ ai_gen_id }} ai-icon-grid__button-{{ ai_gen_id }}--{{ block.settings.button_style }}"
      >
        {{ block.settings.button_text }}
      </a>
    </div>
  {% endif %}
</icon-grid-{{ ai_gen_id }}>

<script>
(function() {
  class IconGrid{{ ai_gen_id }} extends HTMLElement {
    constructor() {
      super();
      this.layoutMobile = '{{ block.settings.layout_mobile }}';
      this.layoutDesktop = '{{ block.settings.layout_desktop }}';
      this.columnsMobile = {{ block.settings.columns_mobile }};
      this.columnsDesktop = {{ block.settings.columns_desktop }};
      this.gapMobile = {{ block.settings.gap_mobile }};
      this.gapDesktop = {{ block.settings.gap_desktop }};
    }

    connectedCallback() {
      this.container = this.querySelector('.ai-icon-grid__layout-container-{{ ai_gen_id }}');
      this.nav = this.querySelector('.ai-icon-grid__nav-{{ ai_gen_id }}');
      this.prevButton = this.querySelector('[data-direction="prev"]');
      this.nextButton = this.querySelector('[data-direction="next"]');
      
      this.updateLayout();
      window.addEventListener('resize', () => this.updateLayout());
      
      if (this.prevButton && this.nextButton) {
        this.prevButton.addEventListener('click', () => this.scroll('prev'));
        this.nextButton.addEventListener('click', () => this.scroll('next'));
      }
      
      if (this.container) {
        this.container.addEventListener('scroll', () => this.updateButtons());
      }
    }

    updateLayout() {
      if (!this.container || !this.nav) return;
      
      const isMobile = window.innerWidth < 750;
      const layout = isMobile ? this.layoutMobile : this.layoutDesktop;
      const columns = isMobile ? this.columnsMobile : this.columnsDesktop;
      const gap = isMobile ? this.gapMobile : this.gapDesktop;
      
      this.container.classList.remove('ai-icon-grid__grid-{{ ai_gen_id }}', 'ai-icon-grid__slider-{{ ai_gen_id }}');
      
      if (layout === 'slider') {
        this.container.classList.add('ai-icon-grid__slider-{{ ai_gen_id }}');
        this.nav.style.display = 'flex';
        
        const items = this.container.querySelectorAll('.ai-icon-grid__item-{{ ai_gen_id }}');
        items.forEach(item => {
          const itemWidth = `calc((100% - (${columns - 1} * ${gap}px)) / ${columns})`;
          item.style.flex = `0 0 ${itemWidth}`;
          item.style.scrollSnapAlign = 'start';
        });
        
        this.updateButtons();
      } else {
        this.container.classList.add('ai-icon-grid__grid-{{ ai_gen_id }}');
        this.nav.style.display = 'none';
        
        const items = this.container.querySelectorAll('.ai-icon-grid__item-{{ ai_gen_id }}');
        items.forEach(item => {
          item.style.flex = '';
          item.style.scrollSnapAlign = '';
        });
      }
    }

    scroll(direction) {
      if (!this.container) return;
      
      const scrollAmount = this.container.clientWidth;
      const scrollLeft = direction === 'prev' ? -scrollAmount : scrollAmount;
      
      this.container.scrollBy({ left: scrollLeft, behavior: 'smooth' });
      
      setTimeout(() => this.updateButtons(), 300);
    }

    updateButtons() {
      if (!this.container || !this.prevButton || !this.nextButton) return;
      
      const isAtStart = this.container.scrollLeft <= 1;
      const isAtEnd = this.container.scrollLeft >= this.container.scrollWidth - this.container.clientWidth - 1;
      
      this.prevButton.disabled = isAtStart;
      this.nextButton.disabled = isAtEnd;
    }
  }

  customElements.define('icon-grid-{{ ai_gen_id }}', IconGrid{{ ai_gen_id }});
})();
</script>

